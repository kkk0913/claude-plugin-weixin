{
  "name": "claude-plugin-weixin",
  "version": "1.0.0",
  "description": "WeChat channel plugin for Claude Code — bridges WeChat to Claude Code via MCP",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/server.js",
  "files": [
    "dist/",
    ".claude-plugin/",
    ".mcp.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "bun install --no-summary && bun src/server.ts",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "npx": "^10.2.2",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.7.0",
    "typescript": "^5.8.0"
  }
}
